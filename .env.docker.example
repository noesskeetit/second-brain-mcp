# Copy to `.env.docker` and edit. The three OBSIDIAN_EMBED_* values are the
# only thing you NEED to fill in — embedding is API-only (no local model
# download). Point at OpenAI, Cloud.ru Foundation Models, Together, vLLM,
# whatever speaks OpenAI /v1/embeddings.

# --- Embedder (required) ---
OBSIDIAN_EMBED_API_URL=https://foundation-models.api.cloud.ru/v1
OBSIDIAN_EMBED_API_KEY=
OBSIDIAN_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
# OBSIDIAN_EMBED_DIMENSIONS=   # optional

# --- Vault ---
# Absolute host path to your Obsidian vault. Defaults to ./template-vault
# (bundled) so compose works with no setup. The vault is mounted read-write;
# obsidian_write mutates notes.
# OBSIDIAN_VAULT_HOST=/Users/you/obsidian/vault

# --- Network exposure ---
#   127.0.0.1 — laptop only (default, safe).
#   0.0.0.0   — reachable from the network; REQUIRES OBSIDIAN_HTTP_TOKEN.
# MCP_BIND_HOST=127.0.0.1
# MCP_HOST_PORT=8765

# --- Auth (required when MCP_BIND_HOST is 0.0.0.0) ---
# Generate: openssl rand -hex 32
# OBSIDIAN_HTTP_TOKEN=
